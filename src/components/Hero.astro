---
/**
 * Home hero — §09 locked copy.
 *
 * Per the deck:
 *   "We map the path. We defend the map."
 *   four-metric Plex Mono rule
 *   primary CTA: See the track record
 *   secondary CTA: Read the methodology
 *
 * No stock photo. No big animated counters. Editorial restraint.
 */
---

<section class="hero" aria-labelledby="hero-headline">
  <div class="frame hero__frame">
    <p class="hero__eyebrow eyebrow" data-reveal>
      A strategic consultancy · Practiced as decision cartography
    </p>

    <h1 id="hero-headline" class="hero__headline" data-reveal>
      <span class="hero__headline-line">We map the path.</span>
      <span class="hero__headline-line">We defend the map.</span>
    </h1>

    <p class="hero__sub" data-reveal>
      Power In Numbers is a strategic consultancy. Our discipline is
      <em>decision cartography</em> &mdash; a proprietary methodology, validated by VERIDEX,
      with thirty-two years of pattern recognition, six firm-built ventures,
      and applications at sovereign fiscal scale. The methodology has been
      proven on us first.
    </p>

    <div class="hero__metrics" data-reveal aria-label="Key metrics">
      <span class="hero__metric">32 years of methodology</span>
      <span class="hero__metric-sep" aria-hidden="true">·</span>
      <span class="hero__metric">6 firm-built ventures</span>
      <span class="hero__metric-sep" aria-hidden="true">·</span>
      <span class="hero__metric">$30B sovereign framework mapped</span>
      <span class="hero__metric-sep" aria-hidden="true">·</span>
      <span class="hero__metric">22/22 VERIDEX gates passing</span>
    </div>

    <div class="hero__cta" data-reveal>
      <a href="/track-record" class="cta cta--primary">See the track record</a>
      <a href="/methodology" class="cta cta--secondary">Read the methodology</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 96px 0 88px;
    border-bottom: 1px solid var(--rule);
    position: relative;
  }
  @media (max-width: 720px) {
    .hero { padding: 64px 0 56px; }
  }

  .hero__eyebrow {
    margin-bottom: 32px;
    color: var(--oxblood);
  }

  .hero__headline {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--fs-hero);
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin-bottom: 36px;
    max-width: 980px;
    color: var(--ink);
  }
  @media (max-width: 720px) {
    .hero__headline { font-size: var(--fs-hero-mobile); }
  }
  .hero__headline-line { display: block; }
  /* Subtle stagger on reveal */
  .hero__headline { transition-delay: 0ms; }
  .hero__sub { transition-delay: .12s; }
  .hero__metrics { transition-delay: .24s; }
  .hero__cta { transition-delay: .36s; }

  .hero__sub {
    font-size: 20px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin-bottom: 48px;
    max-width: 720px;
  }
  @media (max-width: 720px) {
    .hero__sub { font-size: 17px; line-height: 1.6; }
  }
  .hero__sub em { font-style: italic; color: var(--ink); }

  .hero__metrics {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    border-top: 1px solid var(--rule);
    padding-top: 24px;
    margin-bottom: 40px;
    line-height: 1.9;
  }
  .hero__metric { display: inline-block; }
  .hero__metric-sep { color: var(--oxblood); margin: 0 12px; }
  @media (max-width: 720px) {
    .hero__metrics { font-size: 11px; letter-spacing: 0.05em; }
    .hero__metric-sep { margin: 0 8px; }
  }

  .hero__cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
</style>
