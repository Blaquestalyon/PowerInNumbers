---
/**
 * Home — manifesto-led.
 *
 * Composes:
 *   1. Hero (§09 LOCKED)
 *   2. Architecture stack (§03 Fig. 1)
 *   3. Three pillars preview (§03)
 *   4. Track-record preview (dynamic, queries collection — graceful when empty)
 *   5. Library latest (dynamic, queries collection — graceful when empty)
 *   6. Closing engage CTA (three tiers per §06)
 *
 * Voice: restrained, sober, citation-grade. No management-speak.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import ArchitectureStack from '@/components/ArchitectureStack.astro';
import PillarsPreview from '@/components/PillarsPreview.astro';

/* ----------------------------------------------------------------
   Track record preview — pull the four most recent / canonical
   patterns. Graceful when the collection is empty (returns []).
   ---------------------------------------------------------------- */
const allTrackRecord = await getCollection('track-record').catch(() => []);
const trackRecordPreview = allTrackRecord
  .sort((a, b) => (b.data.yearSort ?? 0) - (a.data.yearSort ?? 0))
  .slice(0, 4);

/* ----------------------------------------------------------------
   Library latest — three most recent published.
   ---------------------------------------------------------------- */
const allLibrary = await getCollection('library').catch(() => []);
const libraryLatest = allLibrary
  .filter((e) => !e.data.unlisted)
  .sort(
    (a, b) =>
      new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  )
  .slice(0, 3);

const libraryTypeLabel: Record<string, string> = {
  'white-paper': 'White paper',
  framework: 'Framework',
  'press-essay': 'Press essay',
  'track-record-essay': 'Track-record essay',
  'firm-built-essay': 'Firm-built essay',
  'methodology-note': 'Methodology note',
};

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Power In Numbers — A strategic consultancy. Practiced as decision cartography."
  description="Power In Numbers maps high-stakes decisions for sovereigns, enterprises, and founders. Decision cartography — a proprietary methodology, validated by VERIDEX, with thirty-two years of pattern recognition and six firm-built ventures."
>
  <Hero />

  {/* ──────────────────────────────────────────────────────────
      Section 01 — The architecture
      ────────────────────────────────────────────────────────── */}
  <section class="section" aria-labelledby="arch-heading">
    <div class="frame">
      <div class="section-marker" data-reveal>
        <span class="section-marker__num">§ 01</span>
        <span class="section-marker__rule" aria-hidden="true"></span>
        <span class="section-marker__tag">The architecture</span>
      </div>

      <div class="section-head">
        <h2 id="arch-heading" class="section-head__title" data-reveal>
          A discipline, not a deck of services.
        </h2>
        <p class="section-head__lede" data-reveal>
          Power In Numbers is built as a stack. Worldview underwrites methodology;
          methodology produces outputs; validation governs the whole. The brand is
          the connective tissue.
        </p>
      </div>

      <ArchitectureStack />
    </div>
  </section>

  {/* ──────────────────────────────────────────────────────────
      Section 02 — Three pillars of proof
      ────────────────────────────────────────────────────────── */}
  <section class="section section--paper-deep" aria-labelledby="pillars-heading">
    <div class="frame">
      <div class="section-marker" data-reveal>
        <span class="section-marker__num">§ 02</span>
        <span class="section-marker__rule" aria-hidden="true"></span>
        <span class="section-marker__tag">Three pillars of proof</span>
      </div>

      <div class="section-head">
        <h2 id="pillars-heading" class="section-head__title" data-reveal>
          The methodology has been proven on us first.
        </h2>
        <p class="section-head__lede" data-reveal>
          Most strategy firms validate their thinking with client wins. We validate
          ours by predicting markets before they exist, by building ventures we
          ourselves operate, and by submitting our outputs to VERIDEX gates at
          sovereign scale. Three independent proofs, each on its own page.
        </p>
      </div>

      <PillarsPreview />
    </div>
  </section>

  {/* ──────────────────────────────────────────────────────────
      Section 03 — Track-record preview
      The press-hook centerpiece. Per deck §09.
      ────────────────────────────────────────────────────────── */}
  <section class="section" aria-labelledby="tr-heading">
    <div class="frame">
      <div class="section-marker" data-reveal>
        <span class="section-marker__num">§ 03</span>
        <span class="section-marker__rule" aria-hidden="true"></span>
        <span class="section-marker__tag">Predictive track record</span>
      </div>

      <div class="section-head">
        <h2 id="tr-heading" class="section-head__title" data-reveal>
          Six patterns, each documented before the market named it.
        </h2>
        <p class="section-head__lede" data-reveal>
          A timeline of category-defining moves implemented by Power In Numbers
          five to fifteen years before they became mainstream &mdash; with primary-source
          evidence on each entry.
        </p>
      </div>

      {trackRecordPreview.length > 0 ? (
        <ol class="tr-preview" data-reveal>
          {trackRecordPreview.map((entry) => (
            <li class="tr-row">
              <a href={`/track-record/${entry.id.replace(/\.md$/, '')}`} class="tr-row__link">
                <span class="tr-row__year">{entry.data.year}</span>
                <span class="tr-row__pin">{entry.data.pinImplementation}</span>
                <span class="tr-row__foil">
                  vs. {entry.data.foilCompany ?? entry.data.mainstreamEmergence}
                </span>
                <span class="tr-row__ahead">
                  {entry.data.yearsAhead ? `${entry.data.yearsAhead} yrs ahead` : ''}
                </span>
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <div class="tr-coming" data-reveal>
          <p class="tr-coming__title">The full timeline is being assembled.</p>
          <p class="tr-coming__body">
            Six entries &mdash; from the 2001 employee-as-marketing implementation
            (thirteen years before "employee advocacy" entered the lexicon) through
            the 2017 Foundation El Paso venture (six to eight years before VENU's
            2024 listing) &mdash; with primary-source artifacts on each. Coming
            shortly.
          </p>
        </div>
      )}

      <div class="section-foot" data-reveal>
        <a href="/track-record" class="cta cta--primary">See the full timeline</a>
      </div>
    </div>
  </section>

  {/* ──────────────────────────────────────────────────────────
      Section 04 — Library latest
      ────────────────────────────────────────────────────────── */}
  <section class="section section--paper-deep" aria-labelledby="lib-heading">
    <div class="frame">
      <div class="section-marker" data-reveal>
        <span class="section-marker__num">§ 04</span>
        <span class="section-marker__rule" aria-hidden="true"></span>
        <span class="section-marker__tag">From the library</span>
      </div>

      <div class="section-head">
        <h2 id="lib-heading" class="section-head__title" data-reveal>
          The publishing engine.
        </h2>
        <p class="section-head__lede" data-reveal>
          White papers, frameworks, track-record essays, and case studies. Citation-grade
          where the audience is academic; press-grade where the moment demands it.
        </p>
      </div>

      {libraryLatest.length > 0 ? (
        <ul class="lib-grid" data-reveal>
          {libraryLatest.map((entry) => (
            <li class="lib-card">
              <a href={`/library/${entry.id.replace(/\.md$/, '')}`} class="lib-card__link">
                <span class="lib-card__type">
                  {libraryTypeLabel[entry.data.type] ?? entry.data.type}
                </span>
                <h3 class="lib-card__title">{entry.data.title}</h3>
                <p class="lib-card__summary">{entry.data.summary}</p>
                <p class="lib-card__date">{fmtDate(new Date(entry.data.publishedAt))}</p>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="lib-coming" data-reveal>
          <p class="lib-coming__title">First slate of ten entries publishing soon.</p>
          <ul class="lib-coming__list">
            <li><span class="lib-coming__type">White paper</span> &mdash; <em>Decision Cartography: A Methodology Primer.</em></li>
            <li><span class="lib-coming__type">Framework</span> &mdash; <em>The CROWD POWERED 12-Step Framework.</em></li>
            <li><span class="lib-coming__type">Track-record essay</span> &mdash; <em>What VENU brought to public markets in 2024, Power In Numbers tested in El Paso in 2017.</em></li>
            <li><span class="lib-coming__type">Track-record essay</span> &mdash; <em>The Go Local Magazine: CROWD POWERED in journalism, fifteen years before The International Telegraph.</em></li>
          </ul>
        </div>
      )}

      <div class="section-foot" data-reveal>
        <a href="/library" class="cta cta--secondary">Browse the library</a>
      </div>
    </div>
  </section>

  {/* ──────────────────────────────────────────────────────────
      Section 05 — Engage (three tiers)
      ────────────────────────────────────────────────────────── */}
  <section class="section section--ink" aria-labelledby="engage-heading">
    <div class="frame">
      <div class="section-marker section-marker--inverse" data-reveal>
        <span class="section-marker__num">§ 05</span>
        <span class="section-marker__rule" aria-hidden="true"></span>
        <span class="section-marker__tag">Engage</span>
      </div>

      <div class="section-head section-head--inverse">
        <h2 id="engage-heading" class="section-head__title" data-reveal>
          Three ways to put the methodology to work.
        </h2>
        <p class="section-head__lede" data-reveal>
          We work selectively. Each tier has a separate intake. State the decision
          on the table and the stakes; we will respond with whether and how we can help.
        </p>
      </div>

      <div class="engage-grid" data-reveal>
        <article class="engage-card">
          <span class="engage-card__tier">Tier 01 &middot; Sovereign &amp; institutional</span>
          <h3 class="engage-card__name">Request a sovereign briefing.</h3>
          <p class="engage-card__body">
            Ministries, multilaterals, and sovereign wealth funds. Fiscal frameworks,
            policy architecture, and counterfactual landscapes at $30B-plus scale.
          </p>
          <a href="/engage#sovereign" class="engage-card__cta">Open the sovereign intake &rarr;</a>
        </article>
        <article class="engage-card">
          <span class="engage-card__tier">Tier 02 &middot; Enterprise</span>
          <h3 class="engage-card__name">Map your decision.</h3>
          <p class="engage-card__body">
            For executive teams facing a decision with strategic counterfactuals,
            constituency dynamics, or category-creation stakes. Mapped, scored, defended.
          </p>
          <a href="/engage#enterprise" class="engage-card__cta">Open the enterprise intake &rarr;</a>
        </article>
        <article class="engage-card">
          <span class="engage-card__tier">Tier 03 &middot; Founder &amp; venture</span>
          <h3 class="engage-card__name">Apply for a venture cartography session.</h3>
          <p class="engage-card__body">
            For founders and operators with a venture in motion and a hard question
            on the table. Limited slate; selection is by fit, not first-come.
          </p>
          <a href="/engage#venture" class="engage-card__cta">Apply for a session &rarr;</a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     Section scaffolding
     ============================================================ */
  .section {
    padding: 96px 0;
    border-bottom: 1px solid var(--rule);
  }
  @media (max-width: 720px) {
    .section { padding: 64px 0; }
  }
  .section--paper-deep { background: var(--paper-deep); }
  .section--ink {
    background: var(--ink);
    color: var(--paper);
    border-bottom: none;
  }

  /* ----- Section marker (e.g., § 01 ─── The architecture) ----- */
  .section-marker {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }
  .section-marker__num {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--oxblood);
    font-weight: 500;
  }
  .section-marker__rule {
    flex: 1;
    height: 1px;
    background: var(--rule);
    max-width: 120px;
  }
  .section-marker__tag {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--subtext);
  }
  .section-marker--inverse .section-marker__rule { background: rgba(245, 241, 232, 0.25); }
  .section-marker--inverse .section-marker__tag { color: rgba(245, 241, 232, 0.7); }
  .section-marker--inverse .section-marker__num { color: #D67878; }

  /* ----- Section head ----- */
  .section-head {
    max-width: 760px;
    margin-bottom: 56px;
  }
  .section-head--inverse { color: var(--paper); }
  .section-head__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 40px;
    line-height: 1.15;
    letter-spacing: -0.018em;
    margin: 0 0 20px;
    color: var(--ink);
  }
  .section-head--inverse .section-head__title { color: var(--paper); }
  @media (max-width: 720px) {
    .section-head__title { font-size: 30px; line-height: 1.2; }
  }
  .section-head__lede {
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
  }
  .section-head--inverse .section-head__lede { color: rgba(245, 241, 232, 0.75); }

  /* ----- Section foot (CTA row) ----- */
  .section-foot {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* ============================================================
     Track-record preview
     ============================================================ */
  .tr-preview {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--ink);
  }
  .tr-row { border-bottom: 1px solid var(--rule); }
  .tr-row:last-child { border-bottom: 1px solid var(--ink); }
  .tr-row__link {
    display: grid;
    grid-template-columns: 110px 1fr 1fr 110px;
    align-items: baseline;
    gap: 24px;
    padding: 22px 0;
    color: var(--ink);
    text-decoration: none;
    transition: background 0.18s ease;
  }
  .tr-row__link:hover { background: var(--paper-deep); }
  .tr-row__year {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.06em;
    color: var(--oxblood);
    font-weight: 500;
  }
  .tr-row__pin {
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.4;
    color: var(--ink);
  }
  .tr-row__foil {
    font-size: 14px;
    color: var(--subtext);
    line-height: 1.5;
  }
  .tr-row__ahead {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--oxblood);
    text-align: right;
  }
  @media (max-width: 860px) {
    .tr-row__link {
      grid-template-columns: 1fr;
      gap: 6px;
      padding: 18px 0;
    }
    .tr-row__ahead { text-align: left; }
  }

  /* ----- Track record "coming soon" placeholder ----- */
  .tr-coming {
    border: 1px solid var(--rule);
    background: var(--paper-deep);
    padding: 32px;
    max-width: 720px;
  }
  .tr-coming__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 20px;
    color: var(--ink);
    margin: 0 0 12px;
  }
  .tr-coming__body {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
  }

  /* ============================================================
     Library grid
     ============================================================ */
  .lib-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--ink);
    border-left: 1px solid var(--ink);
  }
  @media (max-width: 860px) {
    .lib-grid { grid-template-columns: 1fr; }
  }
  .lib-card {
    border-right: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    background: var(--paper);
  }
  .lib-card__link {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px 24px;
    color: var(--ink);
    text-decoration: none;
    height: 100%;
    transition: background 0.18s ease;
  }
  .lib-card__link:hover { background: var(--paper-deep); }
  .lib-card__type {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--oxblood);
  }
  .lib-card__title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.005em;
    margin: 0;
    color: var(--ink);
  }
  .lib-card__summary {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
    flex: 1;
  }
  .lib-card__date {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--subtext);
    margin: 0;
  }

  /* ----- Library "coming soon" placeholder ----- */
  .lib-coming {
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: 32px;
    max-width: 760px;
  }
  .lib-coming__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 20px;
    color: var(--ink);
    margin: 0 0 20px;
  }
  .lib-coming__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .lib-coming__list li {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
    padding-left: 16px;
    border-left: 2px solid var(--oxblood);
  }
  .lib-coming__list em { font-style: italic; color: var(--ink); }
  .lib-coming__type {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--oxblood);
  }

  /* ============================================================
     Engage grid (inverse)
     ============================================================ */
  .engage-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid rgba(245, 241, 232, 0.25);
  }
  @media (max-width: 860px) {
    .engage-grid { grid-template-columns: 1fr; }
  }
  .engage-card {
    padding: 32px 28px;
    border-right: 1px solid rgba(245, 241, 232, 0.25);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .engage-card:last-child { border-right: none; }
  @media (max-width: 860px) {
    .engage-card {
      border-right: none;
      border-bottom: 1px solid rgba(245, 241, 232, 0.25);
    }
    .engage-card:last-child { border-bottom: none; }
  }
  .engage-card__tier {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #D67878;
  }
  .engage-card__name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--paper);
  }
  .engage-card__body {
    font-size: 15px;
    line-height: 1.6;
    color: rgba(245, 241, 232, 0.75);
    margin: 0;
    flex: 1;
  }
  .engage-card__cta {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper);
    text-decoration: none;
    border-bottom: 1px solid rgba(245, 241, 232, 0.4);
    padding-bottom: 4px;
    align-self: flex-start;
    transition: border-color 0.18s ease, color 0.18s ease;
  }
  .engage-card__cta:hover {
    color: #F5E1A8;
    border-color: #F5E1A8;
  }
</style>
