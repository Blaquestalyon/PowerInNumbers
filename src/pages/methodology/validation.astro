</BaseLayout>

<style>
  /* ───── Section primitives (mirrors framework / curriculum) ───── */
  .section { padding: 96px 0; }
  .section--paper-deep { background: var(--paper-deep); }
  .section--ink { background: var(--ink); color: var(--paper); }
  .frame { max-width: 1180px; margin: 0 auto; padding: 0 32px; }
  @media (max-width: 700px) { .section { padding: 72px 0; } .frame { padding: 0 22px; } }

  /* ───── Prose ───── */
  .prose { max-width: 72ch; }
  .prose p { font-size: 18px; line-height: 1.7; color: var(--ink); margin-bottom: 22px; }
  .prose__sub { font-size: 17px; line-height: 1.65; color: var(--subtext); max-width: 72ch; margin: 0 0 36px; }
  .prose__sub--ink { color: rgba(245,241,232,0.78); }

  /* ───── Section titles ───── */
  .s-title { font-family: var(--font-display); font-weight: 400; font-size: clamp(30px, 4.2vw, 44px); line-height: 1.15; letter-spacing: -0.012em; color: var(--ink); margin: 4px 0 28px; max-width: 28ch; }
  .s-title--ink { color: var(--paper); }
  .sub-title { font-family: var(--font-display); font-weight: 400; font-size: 22px; line-height: 1.25; color: var(--ink); margin: 48px 0 16px; }

  /* ───── §02 architecture diagram ───── */
  .arch { display: grid; gap: 14px; }
  .arch__row { display: grid; gap: 14px; }
  .arch__row--engines { grid-template-columns: repeat(3, 1fr); }
  @media (max-width: 880px) { .arch__row--engines { grid-template-columns: 1fr; } }
  .arch__cell { background: var(--paper); border: 1px solid var(--rule); padding: 24px 26px; }
  .arch__cell--audit { border-left: 4px solid var(--oxblood); background: var(--paper); }
  .arch__cell--gates { border-left: 4px solid var(--ink); background: var(--paper); }
  .arch__layer { display: block; font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--subtext); margin-bottom: 8px; }
  .arch__name { font-family: var(--font-display); font-weight: 400; font-size: 22px; color: var(--ink); margin: 0 0 6px; }
  .arch__sub { font-size: 13px; color: var(--oxblood); font-style: italic; margin: 0 0 12px; }
  .arch__body { font-size: 15px; line-height: 1.6; color: var(--subtext); margin: 0; }

  /* ───── §03 / §04 gate cards ───── */
  .gate-family { margin-bottom: 56px; }
  .gate-family__title { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--oxblood); border-top: 1px solid var(--rule); padding-top: 20px; margin: 0 0 24px; }
  .gates { list-style: none; margin: 0; padding: 0; display: grid; gap: 18px; }
  .gates--ext { gap: 18px; }
  .gate { display: grid; grid-template-columns: 80px 1fr; gap: 22px; padding: 22px 24px; background: var(--paper); border: 1px solid var(--rule); }
  .gate--ext { background: var(--paper); border-left: 4px solid var(--oxblood); }
  @media (max-width: 600px) { .gate { grid-template-columns: 1fr; gap: 12px; } }
  .gate__num { font-family: var(--font-mono); font-size: 13px; letter-spacing: 0.08em; color: var(--oxblood); padding-top: 4px; }
  .gate__num--ext { color: var(--oxblood); }
  .gate__body { max-width: 64ch; }
  .gate__title { font-family: var(--font-display); font-weight: 400; font-size: 19px; line-height: 1.3; color: var(--ink); margin: 0 0 8px; }
  .gate__text { font-size: 15.5px; line-height: 1.65; color: var(--subtext); margin: 0; }

  /* ───── §05 source tiers ───── */
  .tiers { list-style: none; margin: 0 0 16px; padding: 0; display: grid; gap: 14px; }
  .tier { display: grid; grid-template-columns: 60px 1fr; gap: 22px; padding: 20px 24px; background: var(--paper); border: 1px solid var(--rule); }
  @media (max-width: 600px) { .tier { grid-template-columns: 1fr; gap: 8px; } }
  .tier__num { font-family: var(--font-mono); font-size: 13px; letter-spacing: 0.08em; color: var(--oxblood); padding-top: 4px; }
  .tier__name { font-family: var(--font-display); font-weight: 400; font-size: 19px; color: var(--ink); margin: 0 0 6px; }
  .tier__ex { font-size: 14.5px; line-height: 1.6; color: var(--subtext); margin: 0; }
  .non-sources { list-style: none; margin: 0; padding: 0; display: grid; gap: 8px; max-width: 78ch; }
  .non-source { padding: 10px 16px; border-left: 3px solid var(--oxblood); background: var(--paper); font-size: 14.5px; line-height: 1.55; color: var(--subtext); }

  /* ───── §06 refusal list ───── */
  .refusals { list-style: none; counter-reset: r; margin: 0; padding: 0; display: grid; gap: 14px; max-width: 80ch; }
  .refusal { display: grid; grid-template-columns: 56px 1fr; gap: 18px; padding: 16px 0; border-top: 1px solid rgba(245,241,232,0.18); }
  .refusal:first-child { border-top: none; }
  .refusal__num { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.16em; color: var(--oxblood); padding-top: 4px; }
  .refusal__text { font-size: 17px; line-height: 1.55; color: var(--paper); }

  /* ───── §07 engine cards ───── */
  .engines { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 880px) { .engines { grid-template-columns: 1fr; } }
  .engine { background: var(--paper); border: 1px solid var(--rule); border-top: 4px solid var(--ink); padding: 26px 26px 22px; display: flex; flex-direction: column; }
  .engine__layer { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--subtext); margin-bottom: 8px; }
  .engine__name { font-family: var(--font-display); font-weight: 400; font-size: 24px; color: var(--ink); margin: 0 0 8px; }
  .engine__subject { font-size: 14px; line-height: 1.55; color: var(--oxblood); font-style: italic; margin: 0 0 14px; }
  .engine__deliverable { font-size: 14.5px; line-height: 1.6; color: var(--subtext); margin: 0 0 16px; }
  .engine__cta { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--oxblood); text-decoration: none; margin-top: auto; padding-top: 12px; border-top: 1px solid var(--rule); }
  .engine__cta:hover { color: var(--ink); }

  /* ───── §08 read-further row ───── */
  .next-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  @media (max-width: 880px) { .next-row { grid-template-columns: 1fr; } }
  .next-card { display: grid; gap: 8px; padding: 22px 24px; background: var(--paper); border: 1px solid var(--rule); text-decoration: none; transition: border-color 180ms ease; }
  .next-card:hover { border-color: var(--ink); }
  .next-card__num { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--subtext); }
  .next-card__name { font-family: var(--font-display); font-weight: 400; font-size: 22px; color: var(--ink); }
  .next-card__qual { font-size: 13.5px; color: var(--subtext); }

  /* ───── Reveal-on-scroll ───── */
  [data-reveal] { opacity: 0; transform: translateY(14px); transition: opacity 600ms ease, transform 600ms ease; }
  [data-reveal].is-revealed { opacity: 1; transform: none; }
</style>

<script>
  // Reveal-on-scroll observer (matches framework / curriculum)
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          io.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.06, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
</script>
