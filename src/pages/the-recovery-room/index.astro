---
/**
 * /the-recovery-room — seminar sales page.
 *
 * Promotes The Recovery Room tax strategy seminar for healthcare practitioners.
 * Developed in partnership with Tax2Go DeSoto and The 144K Collective LLC.
 * Fully IRS, HIPAA, and GAAP compliant.
 *
 * Two CTAs:
 *   1. Enroll in seminar — https://ticketstripe.com/therecoveryroom_seminar
 *   2. Obtain materials only (within 1 business day) — PayPal link
 *
 * Voice rules: restrained, sober, citation-grade. No exclamation points.
 * No "revolutionary," "leverage," "synergy," "world-class," etc.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import SectionMarker from '@/components/SectionMarker.astro';

const SEMINAR_URL = 'https://ticketstripe.com/therecoveryroom_seminar';
const MATERIALS_URL = 'https://www.paypal.com/ncp/payment/V5VWXU4X84L64';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  '@id': 'https://power-in-numbers.net/the-recovery-room/#event',
  name: 'The Recovery Room — Advanced Tax Strategy Seminar for Health Practitioners',
  description:
    'A private tax-strategy seminar for Houston operating-room practitioners. IRC §166 and §1001 strategy, fully compliant with IRS, HIPAA, and GAAP.',
  startDate: '2026-05-29T13:30:00-05:00',
  endDate: '2026-05-30T20:00:00-05:00',
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: 'The Powerhouse Estate',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '1119 River Glyn Drive',
      addressLocality: 'Houston',
      addressRegion: 'TX',
      postalCode: '77063',
      addressCountry: 'US',
    },
  },
  organizer: { '@id': 'https://power-in-numbers.net/#organization' },
  offers: {
    '@type': 'Offer',
    name: 'V.I.P.',
    price: '999',
    priceCurrency: 'USD',
    availability: 'https://schema.org/LimitedAvailability',
    url: SEMINAR_URL,
    validFrom: '2026-05-01',
  },
};
---

<BaseLayout
  title="The Recovery Room — Advanced Tax Strategy Seminar | Power In Numbers"
  description="A private tax-strategy seminar for Houston&#8217;s operating-room practitioners. IRC §166 and §1001 strategy, fully compliant with IRS, HIPAA, and GAAP. Developed by Power In Numbers in partnership with Tax2Go DeSoto and The 144K Collective."
  jsonLd={pageSchema}
>

  <PageHero
    eyebrow="Power In Numbers · Tax2Go DeSoto · The 144K Collective"
    headline="The Recovery Room"
    lede="Same income. A different tax bill. A private seminar for Houston&#8217;s operating-room practitioners — built around a documented, IRS-compliant strategy most CPAs have never raised with you."
    metaLeft="May 29–30, 2026 · Houston, Texas"
    metaRight="IRS · HIPAA · GAAP Compliant"
  />

  <!-- §01 — The audience -->
  <section class="section rr-section" aria-label="Who this is for">
    <div class="frame">
      <SectionMarker num="§ 01" tag="The audience" />
      <div class="rr-two-col" data-reveal>
        <div class="rr-col-body">
          <h2 class="rr-h2">Built for operating-room practitioners.</h2>
          <p data-reveal>Surgeons. Anesthesiologists. Nurse practitioners. Certified Registered Nurse Anesthetists. Doctors of Nurse Anesthesia Practice. Whether you are compensated on a W-2, a 1099, direct-bill, or any combination of the three, this seminar addresses your situation directly.</p>
          <p data-reveal>The strategy is grounded in two sections of the Internal Revenue Code — §166 and §1001 — that almost no CPA is discussing with this audience. The reason is not that the strategy is unavailable. It is that the compliance framework required to implement it correctly has not existed in a form that practitioners can access and act on.</p>
          <p data-reveal>Power In Numbers assembled that framework. Tax2Go DeSoto provides the tax-preparation and documentation infrastructure to implement it. The Recovery Room is how it is taught.</p>
        </div>
        <div class="rr-col-aside">
          <div class="rr-stat-block" data-reveal>
            <div class="rr-stat">
              <span class="rr-stat__num">$20,000+</span>
              <span class="rr-stat__label">Annual deduction generated by past implementing practitioners — recurring, every year the strategy is in place</span>
            </div>
            <div class="rr-stat">
              <span class="rr-stat__num">20&times;</span>
              <span class="rr-stat__label">Minimum return on the cost of admission, before the strategy repeats</span>
            </div>
            <div class="rr-stat">
              <span class="rr-stat__num">25</span>
              <span class="rr-stat__label">Seats per session. Each session is capped. Once it sells out, it is closed.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- §02 — The compliance perimeter -->
  <section class="section rr-section" aria-label="Compliance basis">
    <div class="frame">
      <SectionMarker num="§ 02" tag="Compliance basis" />
      <h2 class="rr-h2" data-reveal>Verified compliant. Three standards. No ambiguity.</h2>
      <p class="rr-lede" data-reveal>The strategy is not a grey area. It is not a workaround. It is a documented application of settled federal tax law, operated within a compliance perimeter that covers every material risk.</p>
      <div class="rr-compliance-grid" data-reveal>
        <div class="rr-compliance-card">
          <div class="rr-compliance-card__badge">IRS</div>
          <h3 class="rr-compliance-card__title">Internal Revenue Code</h3>
          <p class="rr-compliance-card__body">The strategy is grounded in IRC §166 (business bad-debt deductions) and §1001 (gain or loss on disposition of property). Tax positions are supported by contemporaneous fair-market-value memoranda and per-transaction workpapers. Reportable-transaction screening is performed annually. The economic-substance standard of IRC §7701(o) is addressed in the compliance documentation.</p>
        </div>
        <div class="rr-compliance-card">
          <div class="rr-compliance-card__badge">HIPAA</div>
          <h3 class="rr-compliance-card__title">Health Information Privacy</h3>
          <p class="rr-compliance-card__body">Every data transfer occurs under a Business Associate Agreement. Only the minimum-necessary fields required for account administration are transferred. Administrative, physical, and technical safeguards are documented. Transfer inventories are maintained. Breach-notification protocols are in place. The framework operates within 45 C.F.R. Parts 160 and 164.</p>
        </div>
        <div class="rr-compliance-card">
          <div class="rr-compliance-card__badge">GAAP</div>
          <h3 class="rr-compliance-card__title">Accounting Standards</h3>
          <p class="rr-compliance-card__body">Participation requires accrual-method accounting — the method under which the receivables were originally recognised as income. Cash-basis practitioners are supported through an accrual-method transition before the first transaction. The accounting treatment is consistent with GAAP and with IRC §446 method-consistency requirements.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- §03 — The W-2 question -->
  <section class="section rr-section rr-section--tinted" aria-label="W-2 clarification">
    <div class="frame">
      <SectionMarker num="§ 03" tag="The most common question" />
      <div class="rr-pullquote-block" data-reveal>
        <p class="rr-pullquote">"Can I do this if I am a W-2 employee?"</p>
        <p class="rr-pullquote-answer">Yes &mdash; through a different path.</p>
      </div>
      <p data-reveal>The same underlying strategy applies across all three practitioner structures: W-2, 1099, and direct-bill (charging the patient directly). The execution path is different for each, and the paths are not equally straightforward.</p>
      <div class="rr-path-grid" data-reveal>
        <div class="rr-path-card">
          <div class="rr-path-card__label">Direct-bill</div>
          <p class="rr-path-card__body">Practitioners who invoice patients directly originate the receivable themselves. The accrual-method recognition, the portfolio sale, and the &sect;166&nbsp;/&nbsp;&sect;1001 deduction mechanics apply most directly to this structure. The path from receivable to tax position is the most direct of the three.</p>
        </div>
        <div class="rr-path-card">
          <div class="rr-path-card__label">1099</div>
          <p class="rr-path-card__body">Independent contractors compensated on a 1099 basis have flexibility in how receivables are structured and reported. The strategy applies, with specific mechanics that depend on how the practitioner&#8217;s business is organised. The action plan addresses this path explicitly.</p>
        </div>
        <div class="rr-path-card rr-path-card--flagged">
          <div class="rr-path-card__label">W-2 &mdash; <span class="rr-path-note">additional steps required</span></div>
          <p class="rr-path-card__body">W-2 employees do not originate receivables in the same manner as direct-bill or 1099 practitioners. The path to offsetting W-2 income is not a direct write-off &mdash; it involves additional steps and a different implementation sequence. The strategy still applies, and that sequence is fully documented in the written action plan and explained in the seminar. Do not self-disqualify before you understand the path.</p>
        </div>
      </div>
      <p data-reveal>All three paths use the same underlying strategy, executed in a manner appropriate to each compensation structure. Every path &mdash; including any combination of W-2, 1099, and direct-bill &mdash; is covered in the seminar and documented in the written action plan delivered to each attendee.</p>
    </div>
  </section>

  <!-- §04 — What you take home -->
  <section class="section rr-section" aria-label="What you take home">
    <div class="frame">
      <SectionMarker num="§ 04" tag="What you take home" />
      <h2 class="rr-h2" data-reveal>You leave with a written action plan.</h2>
      <p class="rr-lede" data-reveal>The seminar does not end with a concept. The deliverable is a complete written action plan, ready to execute with your tax preparer.</p>
      <ul class="rr-deliverables-list" data-reveal>
        <li class="rr-deliverable">
          <span class="rr-deliverable__num">01</span>
          <div>
            <strong>The full strategy — legal basis explained.</strong> IRC §166 and §1001, applied to your receivable profile. The three-bucket structure that determines how each account is treated. The exact documentation required to support the position.
          </div>
        </li>
        <li class="rr-deliverable">
          <span class="rr-deliverable__num">02</span>
          <div>
            <strong>Every restriction and edge case.</strong> What qualifies. What does not. Where the compliance guardrails sit. What doing this wrong costs — and why Tax2Go DeSoto&#8217;s preparation guarantee covers you when it is done correctly.
          </div>
        </li>
        <li class="rr-deliverable">
          <span class="rr-deliverable__num">03</span>
          <div>
            <strong>The implementation path for your situation.</strong> W-2, 1099, direct-bill, or any combination. Each path uses the same strategy executed differently &mdash; and W-2 practitioners face additional steps that are documented explicitly in the action plan. Accrual-basis or transitioning. Texas-based or multi-state receivable mix. No path is left undocumented.
          </div>
        </li>
        <li class="rr-deliverable">
          <span class="rr-deliverable__num">04</span>
          <div>
            <strong>Direct access to the professionals in the room.</strong> Real-time Q&amp;A with the financial professionals teaching the strategy. Peer conversation with other operating-room practitioners who are evaluating the same questions. The Powerhouse Estate is a small room by design.
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- §05 — The partnership -->
  <section class="section rr-section" aria-label="Partnership">
    <div class="frame">
      <SectionMarker num="§ 05" tag="The partnership" />
      <h2 class="rr-h2" data-reveal>Assembled by three parties. Delivered as one strategy.</h2>
      <div class="rr-partners-grid" data-reveal>
        <div class="rr-partner">
          <div class="rr-partner__name">Power In Numbers</div>
          <p class="rr-partner__role">Analytical and compliance architecture. Power In Numbers assembled Compliance Framework v3.1 — the fifteen-section operational standard governing the sale of cash-pay medical receivables, the corresponding federal tax treatment, and the full compliance perimeter across IRS, HIPAA, GAAP, and Texas state law. See the <a href="/case-studies/the-recovery-room/" class="rr-inline-link">case study</a> for the documented framework.</p>
        </div>
        <div class="rr-partner">
          <div class="rr-partner__name">Tax2Go DeSoto</div>
          <p class="rr-partner__role">Tax preparation and documentation infrastructure. Tax2Go DeSoto provides the per-client Tax Memoranda, per-submission FMV Memoranda, per-batch workpapers, Form 4797 preparation, and the compliance guarantee for practitioners who engage Tax2Go DeSoto to prepare their taxes.</p>
        </div>
        <div class="rr-partner">
          <div class="rr-partner__name">The 144K Collective LLC</div>
          <p class="rr-partner__role">Buyer capacity. The 144K Collective LLC acquires full ownership of qualifying receivables — bearing all collection risk, filing the UCC-1 Financing Statement, and operating under a Business Associate Agreement that governs every data transfer. The transaction is a true sale: no recourse to the provider, full removal from the provider&#8217;s books.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- §06 — Sessions and enrollment -->
  <section class="section rr-section rr-section--accent" aria-label="Sessions and enrollment" id="enroll">
    <div class="frame">
      <SectionMarker num="§ 06" tag="Sessions &amp; enrollment" />
      <h2 class="rr-h2 rr-h2--light" data-reveal>Twenty-five seats per session.</h2>
      <p class="rr-session-lede" data-reveal>The Recovery Room runs May 29&#8211;30, 2026 at The Powerhouse Estate, Houston, Texas. Four sessions across two days. Once a session closes, it closes.</p>

      <div class="rr-sessions-grid" data-reveal>
        <div class="rr-session-card">
          <div class="rr-session-card__date">Friday, May 29</div>
          <div class="rr-session-card__times">
            <span>1:30 PM</span>
            <span>6:00 PM</span>
          </div>
        </div>
        <div class="rr-session-card">
          <div class="rr-session-card__date">Saturday, May 30</div>
          <div class="rr-session-card__times">
            <span>1:30 PM</span>
            <span>6:00 PM</span>
          </div>
        </div>
      </div>

      <div class="rr-venue-line" data-reveal>
        The Powerhouse Estate &middot; 1119 River Glyn Drive, Houston, TX 77063
      </div>

      <div class="rr-cta-group" data-reveal>
        <div class="rr-cta-primary-wrap">
          <a href={SEMINAR_URL} target="_blank" rel="noopener noreferrer" class="cta cta--primary rr-cta-primary">
            Reserve your seat — $999
          </a>
          <p class="rr-cta-fine">V.I.P. enrollment · E-ticket · 25 seats per session · Tax2Go DeSoto compliance guarantee included</p>
        </div>
      </div>
    </div>
  </section>

  <!-- §07 — Materials-only option -->
  <section class="section rr-section section--last" aria-label="Materials without attending">
    <div class="frame">
      <SectionMarker num="§ 07" tag="Can&#8217;t attend in person?" />
      <h2 class="rr-h2" data-reveal>Obtain the strategy within one business day.</h2>
      <p data-reveal>If in-person attendance is not possible, the complete Recovery Room strategy materials are available by direct delivery — within one business day of payment. The same written action plan. The same documented framework. Delivered to you without requiring you to be in the room.</p>
      <p data-reveal>The reason to attend in person is access: direct conversation with the financial professionals teaching the strategy, real-time Q&amp;A, and peer exchange with other practitioners in the same position. The materials transfer the strategy. Everything else happens in the room.</p>
      <div class="rr-cta-group rr-cta-group--secondary" data-reveal>
        <a href={MATERIALS_URL} target="_blank" rel="noopener noreferrer" class="cta cta--secondary rr-cta-secondary">
          Obtain materials — delivered within one business day
        </a>
        <p class="rr-cta-fine rr-cta-fine--secondary">Payment via PayPal · Materials delivered within one business day · Written action plan included</p>
      </div>
      <p class="rr-disclaimer" data-reveal>The Recovery Room is educational and strategic. On-site tax advice is provided as a community service by Tax2Go DeSoto, a certified tax preparer. Attendees may engage Tax2Go DeSoto, retain their own advisor, or self-implement. The strategy may not suit every taxpayer&#8217;s facts. Consult a qualified tax advisor for advice specific to your situation.</p>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── page-level layout ── */
  .rr-section { }

  .rr-section--tinted {
    background: var(--paper-deep);
  }

  .rr-section--accent {
    background: var(--ink);
    color: var(--paper);
    border-bottom: none;
  }

  .rr-two-col {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 64px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .rr-two-col { grid-template-columns: 1fr; gap: 48px; }
  }

  .rr-col-body p { margin-bottom: 20px; }
  .rr-col-body p:last-child { margin-bottom: 0; }

  /* ── headings ── */
  .rr-h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 38px;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: 28px;
    max-width: 720px;
  }
  .rr-h2--light { color: var(--paper); }
  @media (max-width: 720px) {
    .rr-h2 { font-size: 28px; }
  }

  .rr-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 20px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 680px;
    margin-bottom: 40px;
  }

  /* ── stat block ── */
  .rr-stat-block {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--rule);
  }

  .rr-stat {
    padding: 28px 32px;
    border-bottom: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .rr-stat:last-child { border-bottom: none; }

  .rr-stat__num {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 600;
    color: var(--oxblood);
    line-height: 1;
  }

  .rr-stat__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--subtext);
    line-height: 1.5;
  }

  /* ── compliance grid ── */
  .rr-compliance-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--rule);
    margin-top: 48px;
  }
  @media (max-width: 900px) {
    .rr-compliance-grid { grid-template-columns: 1fr; }
  }

  .rr-compliance-card {
    padding: 36px 32px;
    border-right: 1px solid var(--rule);
  }
  .rr-compliance-card:last-child { border-right: none; }
  @media (max-width: 900px) {
    .rr-compliance-card { border-right: none; border-bottom: 1px solid var(--rule); }
    .rr-compliance-card:last-child { border-bottom: none; }
  }

  .rr-compliance-card__badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--oxblood);
    padding: 4px 10px;
    margin-bottom: 16px;
  }

  .rr-compliance-card__title {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 12px;
    letter-spacing: 0.02em;
  }

  .rr-compliance-card__body {
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-soft);
  }

  /* ── path grid ── */
  .rr-path-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--rule);
    margin: 32px 0 36px;
  }
  @media (max-width: 900px) {
    .rr-path-grid { grid-template-columns: 1fr; }
  }

  .rr-path-card {
    padding: 32px 28px;
    border-right: 1px solid var(--rule);
  }
  .rr-path-card:last-child { border-right: none; }
  @media (max-width: 900px) {
    .rr-path-card { border-right: none; border-bottom: 1px solid var(--rule); }
    .rr-path-card:last-child { border-bottom: none; }
  }

  .rr-path-card--flagged {
    border-left: 3px solid var(--oxblood);
    background: var(--paper-deep);
  }
  @media (max-width: 900px) {
    .rr-path-card--flagged { border-left: none; border-top: 3px solid var(--oxblood); }
  }

  .rr-path-card__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--oxblood);
    margin-bottom: 14px;
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }

  .rr-path-note {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--oxblood);
    padding: 2px 8px;
    font-weight: 500;
  }

  .rr-path-card__body {
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-soft);
  }

  /* ── pullquote ── */
  .rr-pullquote-block {
    max-width: 680px;
    margin-bottom: 32px;
  }

  .rr-pullquote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 32px;
    line-height: 1.2;
    color: var(--ink);
    margin-bottom: 12px;
  }
  @media (max-width: 720px) {
    .rr-pullquote { font-size: 24px; }
  }

  .rr-pullquote-answer {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 600;
    color: var(--oxblood);
    margin-bottom: 28px;
  }

  /* ── deliverables list ── */
  .rr-deliverables-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--rule);
    margin-top: 40px;
  }

  .rr-deliverable {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid var(--rule);
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-soft);
    align-items: start;
  }

  .rr-deliverable strong { color: var(--ink); }

  .rr-deliverable__num {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--oxblood);
    padding-top: 3px;
  }

  /* ── partners grid ── */
  .rr-partners-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--rule);
    margin-top: 40px;
  }
  @media (max-width: 900px) {
    .rr-partners-grid { grid-template-columns: 1fr; }
  }

  .rr-partner {
    padding: 36px 32px;
    border-right: 1px solid var(--rule);
  }
  .rr-partner:last-child { border-right: none; }
  @media (max-width: 900px) {
    .rr-partner { border-right: none; border-bottom: 1px solid var(--rule); }
    .rr-partner:last-child { border-bottom: none; }
  }

  .rr-partner__name {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--oxblood);
    margin-bottom: 14px;
  }

  .rr-partner__role {
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-soft);
  }

  .rr-inline-link {
    color: var(--oxblood);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .rr-inline-link:hover { color: var(--ink); }

  /* ── sessions grid ── */
  .rr-session-lede {
    font-size: 18px;
    line-height: 1.6;
    color: rgba(245, 241, 232, 0.75);
    max-width: 600px;
    margin-bottom: 40px;
  }

  .rr-sessions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid rgba(197, 187, 168, 0.3);
    max-width: 640px;
    margin-bottom: 28px;
  }
  @media (max-width: 600px) {
    .rr-sessions-grid { grid-template-columns: 1fr; }
  }

