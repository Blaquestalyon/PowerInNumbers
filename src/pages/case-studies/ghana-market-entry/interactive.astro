  {/* ──────────────────────────────────────────────
      Sidebar scroll-spy + smooth scroll
      ────────────────────────────────────────────── */}
  <script is:inline>
    (function () {
      const navItems = Array.from(document.querySelectorAll('.ix-nav__item'));
      const sections = navItems
        .map((a) => document.getElementById(a.dataset.target))
        .filter(Boolean);

      // Smooth scroll
      navItems.forEach((a) => {
        a.addEventListener('click', (e) => {
          const id = a.dataset.target;
          const tgt = id ? document.getElementById(id) : null;
          if (!tgt) return;
          e.preventDefault();
          tgt.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });

      // Active section spy
      if ('IntersectionObserver' in window) {
        const seen = new Set();
        const setActive = (id) => {
          navItems.forEach((a) => {
            a.classList.toggle('is-active', a.dataset.target === id);
          });
        };
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) seen.add(entry.target.id);
              else seen.delete(entry.target.id);
            });
            // Pick the first section currently in view (top-most)
            for (const sec of sections) {
              if (seen.has(sec.id)) {
                setActive(sec.id);
                break;
              }
            }
          },
          {
            rootMargin: '-30% 0px -55% 0px',
            threshold: [0, 0.25, 0.5, 0.75, 1],
          }
        );
        sections.forEach((s) => io.observe(s));
      }
    })();
  </script>
